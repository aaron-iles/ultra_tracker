        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  name, \n  mile_mark, \n  gmaps_url, \nCASE\n    WHEN COALESCE(\n        NULLIF(arrival_time, '1970-01-01 00:00:00+00'::timestamptz),\n        NULLIF(estimated_arrival_time, '1970-01-01 00:00:00+00'::timestamptz)\n    ) IS NULL\n    THEN '--/-- --:--'\n    \n    ELSE to_char(\n        COALESCE(\n            NULLIF(arrival_time, '1970-01-01 00:00:00+00'::timestamptz),\n            NULLIF(estimated_arrival_time, '1970-01-01 00:00:00+00'::timestamptz)\n        ) AT TIME ZONE '$timezone',\n        'FMMM/FMDD FMHH12:MI AM'\n    )\nEND AS arrival_time,\n  CASE \n    WHEN departure_time = '1970-01-01 00:00:00' THEN '--/-- --:--'\n    ELSE to_char(departure_time AT TIME ZONE '$timezone', 'FMMM/FMDD FMHH12:MI AM')\n  END AS departure_time,\n  is_passed, \n  comments \nFROM aidstations ORDER BY mile_mark;",
          "refId": "A",
