          "rawQuery": true,
          "rawSql": "SELECT\n  EXTRACT(YEAR FROM (a.start_time AT TIME ZONE 'America/New_York'))::int AS Year,\n  COALESCE(SUM(a.distance_mi), 0)::numeric(12,2)  AS \"Distance\",\n  COALESCE(SUM(a.duration_min), 0)::numeric(12,2) AS \"Duration\",\n  COALESCE(SUM(a.gain_ft), 0)                     AS \"Gain\"\nFROM activities a\nGROUP BY year\nORDER BY year DESC;\n",
          "refId": "A",
