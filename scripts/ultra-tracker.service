[Unit]
Description=Ultra Tracker
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/${USER}/ultra-tracker
ExecStart=/home/${USER}/.local/bin/podman-compose up -d
ExecStop=/home/${USER}/.local/bin/podman-compose stop
TimeoutStopSec=10

[Install]
WantedBy=default.target
